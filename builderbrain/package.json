{
  "name": "builderbrain",
  "version": "2.0.0",
  "description": "Local-first AI engineering brain — context, proposals, memory, and verified execution",
  "type": "module",
  "bin": {
    "brain": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:dashboard": "vite build",
    "build:all": "npm run build && npm run build:dashboard",
    "dev": "tsx src/cli/index.ts",
    "dev:dashboard": "vite",
    "serve": "tsx src/api/index.ts",
    "start": "tsx src/api/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@hono/node-server": "^1.12.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.185",
    "better-sqlite3": "^9.0.0",
    "commander": "^12.1.0",
    "hono": "^4.4.0",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
